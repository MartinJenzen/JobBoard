@JobBoard.Api_HostAddress = http://localhost:5000

# Get all jobs
GET {{JobBoard.Api_HostAddress}}/jobs
Accept: application/json

###

# Get paged jobs (page 1, 3 per page)
GET {{JobBoard.Api_HostAddress}}/jobs?_page=1&_per_page=3
Accept: application/json

###

# Get job by id
GET {{JobBoard.Api_HostAddress}}/jobs/1
Accept: application/json

###

# Create job
POST {{JobBoard.Api_HostAddress}}/jobs
Content-Type: application/json
Accept: application/json

{
	"title": "Example Job",
	"type": "Full-Time",
	"description": "Example description",
	"location": "Remote",
	"salary": "$100K",
	"company": {
		"name": "Example Co",
		"description": "Company description",
		"contactEmail": "contact@example.com",
		"contactPhone": "555-000-0000"
	}
}

###

# Update job (replace title with "Updated Job")
PUT {{JobBoard.Api_HostAddress}}/jobs/1
Content-Type: application/json
Accept: application/json

{
	"id": 1,
	"title": "Updated Job",
	"type": "Full-Time",
	"description": "Updated description",
	"location": "Remote",
	"salary": "$110K",
	"company": {
		"name": "Example Co",
		"description": "Company description",
		"contactEmail": "contact@example.com",
		"contactPhone": "555-000-0000"
	}
}

###

# Delete job
DELETE {{JobBoard.Api_HostAddress}}/jobs/1
Accept: application/json

###